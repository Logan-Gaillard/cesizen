// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  nickname  String   @unique
  email     String   @unique
  pwdHash   String   @map("pwd_hash")
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions   Session[]
  informations Information[]
  breathExercices BreathExercices[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_session_user_id")
}

model Information {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  description String
  content   String
  imageURL String   @map("image_url")
  category String
  readTime String   @map("read_time")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_information_user_id")
}

model BreathExercices {
  id       String   @id @default(uuid())
  userId    String   @map("user_id")
  title      String
  description String
  nb_loops   Int
  time_inspire Int
  time_block   Int
  time_expire  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_breath_exercices_user_id")
}

model RateLimitAttempt {
  id        String   @id @default(uuid())
  identifier String
  action    String
  attempts  Int      @default(1)
  lastAttemptAt DateTime @default(now()) @map("last_attempt_at")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([identifier, action])
  @@index([action], name: "idx_ratelimit_action")
  @@index([lastAttemptAt], name: "idx_ratelimit_last_attempt")
}